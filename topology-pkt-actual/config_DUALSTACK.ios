-x-IBM_CNTRL_MLTLYRS0
en
conf t
hostname IBM_CNTRL_MLTLYRS0
ipv6 unicast-routing
ipv6 router ospf 1
router-id 8.8.8.8
passive-interface vlan5
passive-interface vlan10
passive-interface vlan15
passive-interface vlan20
exit
ip routing
int gig1/1/4
no switchport
ip add 192.168.30.218 255.255.255.252
ipv6 address FE80::2 link-local
ipv6 address 2001:DB8:FACA:4::2/64
ipv6 ospf 1 area 1
no sh
description IBM_CNTRL_RTR0 felé, az ISP, Projectenis többi telephelye és a szerverszoba felé. / Towards IBM_CNTRL_RTR0, to ISP, and the server room and different sites of Projectenis.
exit
vlan 5
name WRKFRC1
exit
vlan 10
name WRKFRC2
exit
vlan 15
name HGHRPS
exit
vlan 20
name ADMIN
exit
int vlan 5
description Az IBM_CNTRL_PRJCTPNS első munkacsoportjának fenn tartott VLAN. / A dedicated VLAN for IBM_CNTRL_PRJCTPNS first workforce.
ip add 192.168.30.1 255.255.255.192
ip helper-address 192.168.30.199
ipv6 address FE80::1 link-local
ipv6 address 2001:DB8:FACA:5::1/64
ipv6 nd managed-config-flag
ipv6 dhcp server WRKFRC1v6
ipv6 ospf 1 area 1
no sh
exit
int vlan 10
description Az IBM_CNTRL_PRJCTPNS második munkacsoportjának fenn tartott VLAN. / A dedicated VLAN for IBM_CNTR_PRJCTPNS second workforce.
ip add 192.168.30.65 255.255.255.192
ip helper-address 192.168.30.199
ipv6 address FE80::1 link-local
ipv6 address 2001:DB8:FACA:10::1/64
ipv6 nd managed-config-flag
ipv6 dhcp server WRKFRC2v6
ipv6 ospf 1 area 1
no sh
exit
int vlan 15
description Az IBM_CNTRL_PRJCTPNS vezetőségének fenn tartott VLAN. / A dedicated VLAN for IBM_CNTRL_PRJCTPNS higher ups.
ip add 192.168.30.129 255.255.255.224
ip helper-address 192.168.30.199
ipv6 address FE80::1 link-local
ipv6 address 2001:DB8:FACA:15::1/64
ipv6 nd managed-config-flag
ipv6 dhcp server HGHRPSv6
ipv6 ospf 1 area 1
no sh
exit
int vlan 20
description Az IBM_CNTRL_PRJCTPNS adminisztratív VLAN alhálózata. / The administrative VLAN subnetwork of IBM_CNTRL_PRJCTPNS.
ip add 192.168.30.161 255.255.255.224
ipv6 address FE80::1 link-local
ipv6 address 2001:DB8:FACA:20::1/64
ipv6 ospf 1 area 1
no sh
exit
ipv6 dhcp pool WRKFRC1v6
address prefix 2001:DB8:FACA:5::/64
dns-server 2001:DB8:FACA:1::203
domain-name Projectenis.com
exit
ipv6 dhcp pool WRKFRC2v6
address prefix 2001:DB8:FACA:10::/64
dns-server 2001:DB8:FACA:1::203
domain-name Projectenis.com
exit
ipv6 dhcp pool HGHRPSv6
address prefix 2001:DB8:FACA:15::/64
dns-server 2001:DB8:FACA:1::203
domain-name Projectenis.com
exit
router ospf 1
router-id 8.8.8.8
Network 192.168.30.216 0.0.0.3 area 1
Network 192.168.30.0 0.0.0.63 area 1
Network 192.168.30.64 0.0.0.63 area 1
Network 192.168.30.128 0.0.0.31 area 1
Network 192.168.30.160 0.0.0.31 area 1
passive-interface vlan5
passive-interface vlan10
passive-interface vlan15
passive-interface vlan20
exit
int range gig1/0/23-24
description Trunk switchport kapcsolatok az IBM_CNTRL_PRJCTPNS terület felé, S0 és S1 eszköz felé. / Trunk switchport connections towards the area of IBM_CNTRL_PRJCTPNS, to device of S0 and S1.
switchport mode trunk
switchport trunk native vlan 20
switchport trunk allowed vlan 5,10,15,20
no sh
exit
vtp domain Projectenis.com
vtp version 2
vtp password evildynamo367
vtp mode server
spanning-tree mode rapid-pvst
spanning-tree vlan 5 priority 4096
spanning-tree vlan 10 priority 4096
spanning-tree vlan 15 priority 4096
spanning-tree vlan 20 priority 0
ip domain-name Projectenis.com
enable pass rocketeer63
user Overlord839 password ibmadmin839
user IBMadmin999 password 9rutk9skac9
user Rocket375 password projectenis375
user Rifle622 password projectenis622
crypto key generate rsa
1024

ip ssh version 2
