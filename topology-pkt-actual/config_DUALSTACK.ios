ipv6 address 2001:DB8:FACA:2::2/64
ipv6 ospf 1 area 1
no sh
exit
int se0/3/0
description Egy tartalék kapcsolat IBM_CNTRL_RTR0 felé, az ISP, valamint a Projectenis többi telephelye és az IBM_CNTRL terület felé. / A backup connection towards IBM_CNTRL_RTR0, which leads to ISP, the other sites of Projectenis and to IBM_CNTRL.
ip add 192.168.30.214 255.255.255.252
ipv6 address FE80::2 link-local
ipv6 address 2001:DB8:FACA:3::2/64
ipv6 ospf 1 area 1
no sh
exit
int gig0/0
description A Projectenis szerverszobája felé. / Towards the server room of Projectenis.
ip add 192.168.30.193 255.255.255.240
ipv6 address FE80::1 link-local
ipv6 address 2001:DB8:FACA:1::1/64
ipv6 ospf 1 area 1
no sh
exit
router ospf 1
router-id 9.9.9.9
Network 192.168.30.192 0.0.0.15 area 1
Network 192.168.30.208 0.0.0.3 area 1
Network 192.168.30.212 0.0.0.3 area 1
passive-interface gig0/0
exit
ip domain-name Projectenis.com
enable pass leaper25
user Overlord839 password ibmadmin839
user IBMadmin999 password 9rutk9skac9
user Servermanager521 password definitum521
user Rocket375 password projectenis375
user Rifle622 password projectenis622
crypto key generate rsa
1024

ip ssh version 2
ip ssh authentication-retries 2
ip ssh time-out 120
line vty 0 15
transport input ssh
login local
exit
banner motd %This device is only accesable by registered authorized personnel within work hours. Accessing the device unregurarly, or any tampering that damages the owners and the comapny, will result in legal action being taken.%
