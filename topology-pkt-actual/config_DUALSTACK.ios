-x-
------x--------- IPv4 + IPv6 - Dualstack

---------x--------- IBM_CNTR_PRJCTPNS

-x-IBM_CNTRL_RTR0
en
conf t
license boot module c2900 technology-package securityk9
yes
do wr
do reload

en
conf t
hostname IBM_CNTRL_RTR0
ipv6 unicast-routing
ipv6 router ospf 1
router-id 10.10.10.10
exit
int gig0/0/0
description IBM_CNTRL_MLTLYRS0 felé, az IBM_PRJCTNS területe felé. / Towards IBM_CNTRL_MLTLYRS0, to the area of IBM_PRCJTNS.
ip add 192.168.30.217 255.255.255.252
ipv6 address FE80::1 link-local
ipv6 address 2001:DB8:FACA:4::1/64
ipv6 ospf 1 area 1
no sh
exit
int gig0/1/0
description IBM_CNTRL_RTR1 felé, a Projectenis szerverszobájához. / Towards IBM_CNTRL_RTR1, to the server room of Projectenis.
ip add 192.168.30.209 255.255.255.252
ipv6 address FE80::1 link-local
ipv6 address 2001:DB8:FACA:2::1/64
ipv6 ospf 1 area 1
no sh
exit
int se0/3/0
description Egy tartalék kapcsolat IBM_CNTRL_RTR1 felé, a Projectenis szerverszobájához. / A backup connection to IBM_CNTRL_RTR1, to the server room of Projectenis.
ip add 192.168.30.213 255.255.255.252
ipv6 address FE80::1 link-local
ipv6 address 2001:DB8:FACA:3::1/64
ipv6 ospf 1 area 1
no sh
exit
int gig0/2/0
description Az ISP területe és a Projectenis telephelyei felé. / Towards the site of the ISP and towards the sites of PRJCTNS.
ip add 80.90.125.33 255.255.255.252
no sh
exit
router ospf 1
router-id 10.10.10.10
network 80.90.125.32 0.0.0.3 area 0
network 192.168.30.212 0.0.0.3 area 1
network 192.168.30.208 0.0.0.3 area 1
network 192.168.30.216 0.0.0.3 area 1
exit
ip domain-name Projectenis.com
enable pass leaper33
user Overlord839 password ibmadmin839
user IBMadmin999 password 9rutk9skac9
user Rocket375 password projectenis375
user Rifle622 password projectenis622
crypto key generate rsa
1024

ip ssh version 2
ip ssh authentication-retries 2
ip ssh time-out 120
line vty 0 15
transport input ssh
login local
exit
banner motd %This device is only accesable by registered authorized personnel within work hours. Accessing the device unregurarly, or any tampering that damages the owners and the comapny, will result in legal action being taken.%
do wr

-x-IBM_CNTRL_RTR1
en
conf t
