network 172.16.10.128 0.0.0.15 area 4
network 172.16.10.144 0.0.0.15 area 4
network 172.16.10.160 0.0.0.3 area 4
network 172.16.10.164 0.0.0.3 area 4
network 80.90.125.48 0.0.0.3 area 0
passive-interface gig0/0.10
passive-interface gig0/0.20
passive-interface gig0/0.30
passive-interface gig0/0.40
passive-interface gig0/0
exit
int gig0/0.10
description Az F1 adminisztratív VLAN alhálózatának fenn tartott al-interface az első HSRP csoporton belül. / The administrative inside the first HSRP group for the VLAN subnetworks subinterface of F1.
encapsulation dot1Q 10 native
ip address 172.16.10.141 255.255.255.240
standby 1 ip 172.16.10.129
standby 1 preempt
standby 1 priority 120
no sh
exit
int gig0/0.20
description Az F1 Linux munkacsapatnak fenn tartott VLAN al-interface a második HSRP csoporton belül. / The subinterface inside the second HSRP group for the VLAN subnetwork of the Linux team in F1.
encapsulation dot1Q 20
ip address 172.16.10.61 255.255.255.192
standby 2 ip 172.16.10.1
standby 2 preempt
standby 2 priority 120
ip helper-address 80.90.125.33
no sh
exit
int gig0/0.30
description Az F1 Windows munkacsapatnak fenn tartott VLAN al-interface a harmadik HSRP csoporton belül. / The subinterface inside the third HSRP group for the VLAN subnetwork of the Windows team in F1.
encapsulation dot1Q 30
ip address 172.16.10.125 255.255.255.192
standby 3 ip 172.16.10.65
standby 3 preempt
standby 3 priority 120
ip helper-address 80.90.125.33
no sh
exit
int gig0/0.40
description Az F1 vezetőségének fenn tartott VLAN al-interface a negyedik HSRP csoporton belül. / The subinterface inside the fourth HSRP group for the VLAN subnetwork of the Higher ups in F1.
encapsulation dot1Q 40
ip address 172.16.10.157 255.255.255.240
standby 4 ip 172.16.10.145
standby 4 preempt
standby 4 priority 120
ip helper-address 80.90.125.33
no sh
exit
int gig0/2/0
description Az ISP területe és a Projectenis telephelyei felé. / Towards the site of the ISP and towards the sites of PRJCTNS.
ip address 80.90.125.50 255.255.255.252
no sh
exit
int gig0/1
description R2_F1 eszköz felé, amivel egy HSRP csoportban van az F1 területen belül. / Towards the R2_F1 device, with which it's sharing a HSRP group inside F1.
ip address 172.16.10.161 255.255.255.252
no sh
exit
int se0/1/0
description Egy tartalék kapcsolat R2_F1 felé. / A backup connection towards R2_F1.
ip address 172.16.10.165 255.255.255.252
no sh
exit
int gig0/0
no sh
exit
