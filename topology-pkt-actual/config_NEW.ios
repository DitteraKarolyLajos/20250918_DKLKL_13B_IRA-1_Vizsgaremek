yes
do wr
do reload

en
conf t
hostname IBM_CNTRL_RTR0
int gig0/0/0
description IBM_CNTRL_MLTLYRS0 felé, az IBM_PRJCTNS területe felé. / Towards IBM_CNTRL_MLTLYRS0, to the area of IBM_PRCJTNS.
ip add 192.168.30.217 255.255.255.252
ip nat inside
no sh
exit
int gig0/1/0
description IBM_CNTRL_RTR1 felé, a Projectenis szerverszobájához. / Towards IBM_CNTRL_RTR1, to the server room of Projectenis.
ip add 192.168.30.209 255.255.255.252
ip nat inside
no sh
exit
int se0/3/0
description Egy tartalék kapcsolat IBM_CNTRL_RTR1 felé, a Projectenis szerverszobájához. / A backup connection to IBM_CNTRL_RTR1, to the server room of Projectenis.
ip add 192.168.30.213 255.255.255.252
ip nat inside
no sh
exit
int gig0/2/0
description Az ISP területe és a Projectenis telephelyei felé. / Towards the site of the ISP and towards the sites of PRJCTNS.
ip add 80.90.125.33 255.255.255.252
ip nat outside
no sh
exit
