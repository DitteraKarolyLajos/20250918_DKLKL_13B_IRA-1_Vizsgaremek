-x-R_TAV
en
conf t
hostname R_TAV
int vlan 10
description A Projectenis távmunkásainak fenn tartott VLAN. / A dedicated VLAN for the remote workers of Projectenis.
ip address 192.168.100.1 255.255.255.0
ip nat inside
no sh
exit
int gig0/0
description Az ISP területe felé DSL modem-en keresztül. / Towards the ISP trough a DSL modem device.
ip address dhcp
ip nat outside
no sh
exit
int range fa 0/1/0-3
switchport mode access
switchport access vlan 10
spanning-tree portfast
no sh
exit
ip dhcp excluded-address 192.168.100.1
ip dhcp pool TAVMUNKAS
network 192.168.100.0 255.255.255.0
default-router 192.168.100.1
dns-server 192.168.30.196
domain-name Projectenis.com
exit
ip domain-name Projectenis.com
access-list 1 permit 192.168.100.0 0.0.0.255
ip nat inside source list 1 interface gig0/0 overload
banner motd % This device is only accesable by registered authorized personnel within work hours. Accessing the device unregurarly, or any tampering that damages the owners and the comapny, will result in legal action being taken.%


username MAIN_ISP password ispAuth1234
interface Dialer1
ip address negotiated
encapsulation ppp
dialer pool 1
ppp chap hostname MAIN_ISP
ppp chap password ispAuth1234
no sh
exit
int gig 0/0
no ip address
pppoe enable
pppoe-client dial-pool-number 1
no sh
exit
ip route 0.0.0.0 0.0.0.0 Dialer1


do write
